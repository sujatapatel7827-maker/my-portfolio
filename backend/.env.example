PORT=5000
MONGO_URI=mongodb://localhost:27017/portfolioDB

# Optional: SMTP Configuration for sending replies.
# If not provided, the server will fallback to a temporary Ethereal test email account in development.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Portfolio Admin" <your-email@gmail.com>

# Email address where admin notifications for new messages will be sent
ADMIN_EMAIL=s80768012@gmail.com

# URL of the deployed frontend application (used for admin notification links)
FRONTEND_URL=http://localhost:5173


